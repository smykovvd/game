  m_Name: 
  m_EditorClassIdentifier: 
  panelRoot: {fileID: 21092652}
  speakerLabel: {fileID: 827285412}
  bodyText: {fileID: 2108276010}
  speakerName: "\u0424\u0430\u0439\u0440\u0435\u043D"
  lines:
  - "\u0414\u0435\u0440\u0436\u0438\u0441\u044C \u043A\u0440\u0435\u043F\u0447\u0435\u2026
    \u0438\u043B\u0438 \u043E\u0442\u043F\u0443\u0441\u0442\u0438 \u0432\u0441\u0451
    \u0441\u0440\u0430\u0437\u0443."
  - "\u042F \u043F\u0430\u0434\u0430\u043B \u0437\u0434\u0435\u0441\u044C. \u041C\u043D\u043E\u0433\u043E
    \u0440\u0430\u0437."
  - "\u0421\u0432\u043E\u0431\u043E\u0434\u0430 \u0431\u0435\u0437 \u043E\u043F\u043E\u0440\u044B
    \u2014 \u044D\u0442\u043E \u043F\u0430\u0434\u0435\u043D\u0438\u0435. \u042F
    \u043F\u043E\u043D\u044F\u043B \u044D\u0442\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u043F\u043E\u0437\u0434\u043D\u043E."
  - "\u0422\u044B \u0441\u0442\u0430\u043B \u043B\u0435\u0433\u0447\u0435. \u0412\u043E\u043F\u0440\u043E\u0441
    \u2014 \u0447\u0435\u0433\u043E \u0441\u0442\u0430\u043B\u043E \u043C\u0435\u043D\u044C\u0448\u0435?
    \u0418\u043D\u043E\u0433\u0434\u0430 \u043E\u0442\u0432\u0435\u0442 \u2014 \xAB\u043C\u0435\u043D\u044F\xBB."
  playOnStart: 1
  advanceKey: 32
  advanceOnClick: 1
  blockInputWhilePlaying: 1
  onFinished:
    m_PersistentCalls:
      m_Calls: []
