  speakerLabel: {fileID: 2041739901}
  bodyText: {fileID: 1095293618}
  speakerName: "\u0424\u0430\u0439\u0440\u0435\u043D"
  lines:
  - "\u0422\u0435\u043F\u0435\u0440\u044C \u0442\u044B \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0448\u044C
    \u043D\u0435 \u043F\u0443\u0442\u044C. \u0422\u044B \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0448\u044C
    \u0441\u0435\u0431\u044F."
  - "\u0418 \u044D\u0442\u043E \u0442\u0430 \u0447\u0430\u0441\u0442\u044C, \u0433\u0434\u0435
    \u0432\u0441\u0451 \u043E\u0431\u044B\u0447\u043D\u043E \u0438\u0434\u0451\u0442\u2026
    \u0438\u043D\u0430\u0447\u0435."
  - "\u0422\u044B \u0443\u0436\u0435 \u043C\u0435\u043D\u044F\u043B\u0441\u044F.
    \u041F\u0440\u043E\u0441\u0442\u043E \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043B
    \u044D\u0442\u043E\u0433\u043E. \u0422\u044B \u043F\u044B\u0442\u0430\u0435\u0448\u044C\u0441\u044F
    \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u0442\u044C\u2026 \u043D\u0435 \u0442\u0430\u043A
    \u043B\u0438?"
