  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9608fc634f91846fca45b593f8382297, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  panelRoot: {fileID: 1484516561}
  speakerLabel: {fileID: 1207934228}
  bodyText: {fileID: 590263210}
  speakerName: "\u0424\u0430\u0439\u0440\u0435\u043D"
  lines:
  - "\u041E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E. \u0417\u0434\u0435\u0441\u044C
    \u0442\u043E\u043D\u0443\u0442 \u043D\u0435 \u0442\u0435\u043B\u0430."
  - "\u042F \u043E\u0434\u043D\u0430\u0436\u0434\u044B \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u0432\u044B\u0442\u0430\u0449\u0438\u0442\u044C \u043A\u043E\u0433\u043E-\u0442\u043E
    \u043E\u0442\u0441\u044E\u0434\u0430\u2026 \u043E\u043D \u043D\u0435 \u0445\u043E\u0442\u0435\u043B
    \u0443\u0445\u043E\u0434\u0438\u0442\u044C."
  - "\u0421\u043B\u044B\u0448\u0438\u0448\u044C? \u042D\u0442\u043E \u0441\u043B\u043E\u0432\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0442\u0430\u043A \u0438 \u043D\u0435
    \u0441\u0442\u0430\u043B\u0438 \u0437\u0432\u0443\u043A\u043E\u043C. \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0437 \u043D\u0438\u0445 \u2014 \u0442\u0432\u043E\u0438."
  - "\u0418\u0434\u0438 \u043F\u043E \u0441\u0443\u0448\u0435. \u0412 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0440\u0430\u0437 \u043E\u043D\u0438 \u0431\u0443\u0434\u0443\u0442 \u0433\u0440\u043E\u043C\u0447\u0435."
  playOnStart: 1
  advanceKey: 32
  advanceOnClick: 1
  blockInputWhilePlaying: 1
  onFinished:
    m_PersistentCalls:
      m_Calls: []
