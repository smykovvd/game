  m_Name: 
  m_EditorClassIdentifier: 
  panelRoot: {fileID: 296964206}
  speakerLabel: {fileID: 669419173}
  bodyText: {fileID: 652719529}
  speakerName: "\u0424\u0430\u0439\u0440\u0435\u043D"
  lines:
  - "\u041A\u0440\u0430\u0441\u0438\u0432\u043E, \u043F\u0440\u0430\u0432\u0434\u0430?
    \u041F\u0430\u043C\u044F\u0442\u044C \u0432\u0441\u0435\u0433\u0434\u0430 \u0442\u0430\u043A\u0430\u044F\u2026
    \u0441\u043D\u0430\u0447\u0430\u043B\u0430."
  - "\u042F \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0437\u0434\u0435\u0441\u044C
    \u043E\u0434\u043D\u0430\u0436\u0434\u044B. \u041D\u0430\u0434\u043E\u043B\u0433\u043E."
  - "\u0422\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u043E\u0441\u0442\u0430\u0442\u044C\u0441\u044F.
    \u0417\u0434\u0435\u0441\u044C \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u0441\u0442\u0430\u0440\u0435\u0435\u0442.
    \u042F \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u043B."
  - "\u041E\u0442\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u2014 \u043D\u0435 \u0437\u043D\u0430\u0447\u0438\u0442
    \u0437\u0430\u0431\u044B\u0442\u044C. \u0422\u044B \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0448\u044C
    \u044D\u0442\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C."
  playOnStart: 1
  advanceKey: 32
  advanceOnClick: 1
  blockInputWhilePlaying: 1
  onFinished:
    m_PersistentCalls:
      m_Calls: []
