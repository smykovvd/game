--- !u!114 &669419171
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 669419170}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a4533b7b21ce0487ca4e16fdb47e16d1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  endings:
  - text: "\u0420\u0410\u0421\u0422\u0412\u041E\u0420\u0415\u041D\u0418\u0415\n\n\u0422\u044B
      \u0434\u0435\u043B\u0430\u0435\u0448\u044C \u0448\u0430\u0433 \u043D\u0430\u0437\u0430\u0434.
      \u041F\u043E\u0442\u043E\u043C \u0435\u0449\u0451 \u043E\u0434\u0438\u043D.\n\u0427\u0435\u043C
      \u0434\u0430\u043B\u044C\u0448\u0435 \u043E\u0442 \u0441\u0432\u0435\u0442\u0430
      \u2014 \u0442\u0435\u043C \u043B\u0435\u0433\u0447\u0435 \u0434\u044B\u0448\u0430\u0442\u044C.
      \u0421\u043B\u0438\u0448\u043A\u043E\u043C \u043B\u0435\u0433\u043A\u043E.\n\u0418\u043C\u044F
      \u0443\u0441\u043A\u043E\u043B\u044C\u0437\u0430\u0435\u0442. \u041B\u0438\u0446\u043E
      \u2014 \u0442\u043E\u0436\u0435. \u041E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
      \u043B\u0438\u0448\u044C \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435,
      \u0447\u0442\u043E \u0447\u0442\u043E-\u0442\u043E \u0431\u044B\u043B\u043E
      \u0432\u0430\u0436\u043D\u043E. \u041D\u043E \u043D\u0435 \u0437\u0434\u0435\u0441\u044C.
      \u041D\u0435 \u0434\u043B\u044F \u0442\u0435\u0431\u044F.\n\n\u0424\u0430\u0439\u0440\u0435\u043D
      \u2014 \u0434\u0430\u043B\u0435\u043A\u043E, \u043C\u0435\u0436\u0434\u0443
      \u0434\u0435\u0440\u0435\u0432\u044C\u044F\u043C\u0438:\n\xAB\u0422\u044B \u043F\u0440\u043E\u0448\u0451\u043B
      \u0447\u0435\u0440\u0435\u0437 \u043B\u0435\u0441\u2026 \u043D\u0435 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0432
      \u0441\u0435\u0431\u044F. \u042D\u0442\u043E \u0442\u043E\u0436\u0435 \u043F\u0443\u0442\u044C.\xBB\n\xAB\u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u2026
      \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0440\u0430\u0437.\xBB\n\n\u041B\u0435\u0441
      \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0433\u0443\u0449\u0435.
      \u0428\u0430\u0433\u0438 \u2014 \u0442\u0438\u0448\u0435.\n\u0418 \u043E\u0434\u043D\u0430\u0436\u0434\u044B
      \u0438\u0445 \u043D\u0435 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
      \u0432\u043E\u0432\u0441\u0435."
    symbol: {fileID: 0}
  - text: "\u041A\u041E\u041D\u0422\u0420\u041E\u041B\u042C\n\n\u0421\u0435\u0440\u0434\u0446\u0435
      \u043B\u0435\u0441\u0430 \u0431\u044C\u0451\u0442\u0441\u044F. \u041A\u0430\u043A
      \u0431\u0443\u0434\u0442\u043E \u0436\u0434\u0430\u043B\u043E \u0442\u0435\u0431\u044F.\n\u0422\u044B
      \u0438\u0434\u0451\u0448\u044C \u043F\u0440\u044F\u043C\u043E \u043A \u043D\u0435\u043C\u0443.
      \u0422\u0435\u043D\u0438 \u0440\u0430\u0441\u0441\u0442\u0443\u043F\u0430\u044E\u0442\u0441\u044F
      \u2014 \u0443\u0437\u043D\u0430\u044E\u0442.\n\u0422\u044B \u043A\u0430\u0441\u0430\u0435\u0448\u044C\u0441\u044F
      \u0441\u0432\u0435\u0442\u0430 \u2014 \u0438 \u0432\u0441\u0451 \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u0435\u0442\u0441\u044F.\n\u041A\u0430\u0436\u0434\u043E\u0435
      \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u043A\u0430\u0436\u0434\u044B\u0439
      \u0441\u0442\u0440\u0430\u0445 \u2014 \u0442\u0435\u043F\u0435\u0440\u044C
      \u043D\u0435 \u0432\u0440\u0430\u0433\u0438. \u0418\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442.\n\n\u0424\u0430\u0439\u0440\u0435\u043D,
      \u0431\u043B\u0438\u0436\u0435 \u0447\u0435\u043C \u043A\u043E\u0433\u0434\u0430-\u043B\u0438\u0431\u043E,
      \u0431\u0435\u0437 \u0443\u043B\u044B\u0431\u043A\u0438:\n\xAB\u0422\u044B
      \u043F\u043E\u0431\u0435\u0434\u0438\u043B. \u0418 \u0437\u0430\u043D\u044F\u043B
      \u043C\u0435\u0441\u0442\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
      \u0432\u0441\u0435\u0433\u0434\u0430 \u0431\u044B\u043B\u043E \u043F\u0443\u0441\u0442\u044B\u043C.\xBB\n\xAB\u0422\u0435\u043F\u0435\u0440\u044C
      \u0442\u044B \u2014 \u0441\u0435\u0440\u0434\u0446\u0435.\xBB\n\n\u041B\u0435\u0441
      \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u043D\u0430 \u0442\u0435\u0431\u0435
      \u0438 \u043D\u0435 \u043E\u0442\u043F\u0443\u0441\u043A\u0430\u0435\u0442.\n\u0413\u0434\u0435-\u0442\u043E
      \u0434\u0430\u043B\u0435\u043A\u043E \u043A\u0442\u043E-\u0442\u043E \u043F\u0440\u043E\u0441\u044B\u043F\u0430\u0435\u0442\u0441\u044F
      \u043D\u0430 \u043F\u043E\u043B\u044F\u043D\u0435."
    symbol: {fileID: 0}
  - text: "\u041F\u0420\u0418\u041D\u042F\u0422\u0418\u0415\n\n\u0422\u044B \u0434\u0435\u043B\u0430\u0435\u0448\u044C
      \u0448\u0430\u0433 \u0432\u043F\u0435\u0440\u0451\u0434 \u2014 \u0438 \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0448\u044C\u0441\u044F.\n\u041D\u0435
      \u043E\u0442 \u0441\u0442\u0440\u0430\u0445\u0430. \u041F\u0440\u043E\u0441\u0442\u043E
      \u0438\u0434\u0442\u0438 \u0434\u0430\u043B\u044C\u0448\u0435 \u043D\u0435
      \u043D\u0443\u0436\u043D\u043E.\n\u0421\u0432\u0435\u0442 \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F
      \u0442\u0435\u0431\u044F \u0441\u0430\u043C. \u0412\u0441\u0451, \u0447\u0435\u0440\u0435\u0437
      \u0447\u0442\u043E \u0442\u044B \u043F\u0440\u043E\u0448\u0451\u043B, \u043D\u0435
      \u0438\u0441\u0447\u0435\u0437\u043B\u043E \u2014 \u0441\u0442\u0430\u043B\u043E
      \u0447\u0430\u0441\u0442\u044C\u044E \u0442\u0435\u0431\u044F.\n\u0422\u0435\u043D\u0438
      \u2014 \u043D\u0435 \u0432\u0440\u0430\u0433\u0438. \u041F\u0430\u043C\u044F\u0442\u044C
      \u2014 \u043D\u0435 \u043B\u043E\u0432\u0443\u0448\u043A\u0430. \u041F\u0443\u0441\u0442\u043E\u0442\u0430
      \u2014 \u043D\u0435 \u043F\u043E\u0442\u0435\u0440\u044F. \u042D\u0442\u043E
      \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u044B.\n\n\u0424\u0430\u0439\u0440\u0435\u043D
      \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0443\u043B\u044B\u0431\u0430\u0435\u0442\u0441\u044F
      \u043F\u043E-\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443:\n\xAB\u0412\u043E\u0442
      \u0438 \u0432\u0441\u0451. \u041D\u0438\u043A\u0430\u043A\u043E\u0439 \u0442\u0430\u0439\u043D\u044B.
      \u041D\u0438\u043A\u0430\u043A\u043E\u0433\u043E \u0432\u044B\u0445\u043E\u0434\u0430.
      \u041F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435.\xBB\n\n\u041C\u0435\u0436\u0434\u0443
      \u0434\u0435\u0440\u0435\u0432\u044C\u044F\u043C\u0438 \u2014 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439
      \u043F\u0443\u0442\u044C. \u0422\u044B \u0434\u0435\u043B\u0430\u0435\u0448\u044C
      \u0448\u0430\u0433 \u2014 \u0438 \u043E\u043D \u043D\u0435 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442
      \u0442\u0435\u0431\u044F \u043D\u0430\u0437\u0430\u0434.\n\u0422\u044B \u0431\u043E\u043B\u044C\u0448\u0435
      \u043D\u0435 \u0437\u0430\u0431\u043B\u0443\u0434\u0438\u0448\u044C\u0441\u044F.
      \u0414\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u0437\u0430\u0431\u0443\u0434\u0435\u0448\u044C
      \u0434\u043E\u0440\u043E\u0433\u0443."
    symbol: {fileID: 0}
  - text: "\u0424\u0410\u0419\u0420\u0415\u041D\n\n\u0421\u0435\u0440\u0434\u0446\u0435
      \u043B\u0435\u0441\u0430 \u043D\u0435 \u0441\u0432\u0435\u0442\u0438\u0442\u0441\u044F.
      \u041E\u043D\u043E \u0441\u043C\u043E\u0442\u0440\u0438\u0442. \u041A\u0430\u043A
      \u0438 \u0442\u044B.\n\u0418 \u0442\u044B \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C:
      \u0442\u044B \u043D\u0435 \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0437\u0434\u0435\u0441\u044C.
      \u041D\u0435 \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439. \u041D\u0435
      \u0432 \u0442\u0440\u0435\u0442\u0438\u0439.\n\n\u0424\u0430\u0439\u0440\u0435\u043D
      \u0443\u0436\u0435 \u0440\u044F\u0434\u043E\u043C \u2014 \u0431\u0443\u0434\u0442\u043E
      \u0431\u044B\u043B \u0432\u0441\u0435\u0433\u0434\u0430.\n\xAB\u0422\u044B
      \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u043B.\xBB \u041D\u0435 \u0432\u043E\u043F\u0440\u043E\u0441.
      \u0423\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435.\n\u0422\u044B
      \u0441\u043C\u043E\u0442\u0440\u0438\u0448\u044C \u043D\u0430 \u043D\u0435\u0433\u043E
      \u0438 \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0432\u0438\u0434\u0438\u0448\u044C
      \u043D\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u043D\u0438\u043A\u0430.
      \u0410 \u0441\u0435\u0431\u044F \u2014 \u0447\u0443\u0442\u044C \u0441\u0442\u0430\u0440\u0448\u0435,
      \u0447\u0443\u0442\u044C \u0443\u0441\u0442\u0430\u0432\u0448\u0435\u0433\u043E.\n\xAB\u042F
      \u043E\u0441\u0442\u0430\u043B\u0441\u044F. \u041A\u043E\u0433\u0434\u0430
      \u0442\u044B \u0443\u0448\u0451\u043B. \u041A\u0442\u043E-\u0442\u043E \u0434\u043E\u043B\u0436\u0435\u043D
      \u0431\u044B\u043B \u0436\u0434\u0430\u0442\u044C.\xBB\n\n\xAB\u041D\u0430
      \u044D\u0442\u043E\u0442 \u0440\u0430\u0437\u2026 \u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C
      \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u0438\u043D\u0430\u0447\u0435.\xBB\n\u0412\u044B\u0445\u043E\u0434
      \u0435\u0441\u0442\u044C. \u041D\u043E \u043E\u043D \u0441\u0442\u043E\u0438\u0442
      \u0446\u0435\u043D\u044B.\n\n\u041A\u0442\u043E \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
      \u0437\u0434\u0435\u0441\u044C \u2014 \u0442\u044B \u0438\u043B\u0438 \u043E\u043D?"
    symbol: {fileID: 0}
  endingText: {fileID: 1838250521}
  symbolImage: {fileID: 296964207}
  menuSceneName: MainMenu
