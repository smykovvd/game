MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2076030191}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9608fc634f91846fca45b593f8382297, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  panelRoot: {fileID: 1838250518}
  speakerLabel: {fileID: 2119250155}
  bodyText: {fileID: 296964207}
  speakerName: "\u0424\u0430\u0439\u0440\u0435\u043D"
  lines:
  - "\u0422\u0435\u043C\u043D\u043E\u0442\u0430 \u2014 \u044D\u0442\u043E \u043D\u0435
    \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0431\u0435\u0437
    \u0438\u043C\u0435\u043D\u0438."
  - "\u042F \u0434\u0430\u043B \u0438\u043C\u0435\u043D\u0430 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0438\u0437 \u043D\u0438\u0445. \u042D\u0442\u043E \u043D\u0435 \u043F\u043E\u043C\u043E\u0433\u043B\u043E."
  - "\u041E\u043D\u0438 \u043D\u0435 \u043D\u0430\u043F\u0430\u0434\u0430\u043B\u0438
    \u0431\u044B, \u0435\u0441\u043B\u0438 \u0431\u044B \u0442\u044B \u0438\u0445
    \u043D\u0435 \u0437\u043D\u0430\u043B. \u041D\u0435 \u0431\u0435\u0433\u0438.
    \u041D\u0435 \u0431\u043E\u0440\u0438\u0441\u044C. \u0421\u043C\u043E\u0442\u0440\u0438."
  - "\u0422\u044B \u043D\u0435 \u043F\u043E\u0431\u0435\u0434\u0438\u0448\u044C \u0438\u0445.
    \u0422\u044B \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u0448\u044C
    \u0438\u043C \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u044F\u0442\u044C\u0441\u044F
    \u2014 \u0438 \u043E\u043D\u0438 \u0438\u0441\u0447\u0435\u0437\u043D\u0443\u0442."
  playOnStart: 1
  advanceKey: 32
  advanceOnClick: 1
  blockInputWhilePlaying: 1
  onFinished:
    m_PersistentCalls:
      m_Calls: []
